<div class="train-switch">
    <button data-state="0" class="font-type train-yellow"><span>CODE</span> </button>
    <button data-state="1" class="font-type train-blue"> <span>BUILD</span></button>
    <button data-state="2" class="font-type train-green"><span>DEPLOY</span></button>
	<button data-state="3" class="font-type train-white"><span>OFF</button>
</div>

<script is:inline type="module">
    // Define a custom event for communication between components
    const EFFECT_CHANGE_EVENT = 'effect-state-changed';

    // localStorage helper functions
    const saveState = (state) => {
        try {
            localStorage.setItem('effectState', state.toString());
            // Set expiration time (48 hours)
            const expiry = Date.now() + 48 * 60 * 60 * 1000;
            localStorage.setItem('effectStateExpiry', expiry.toString());
        } catch (e) {
            console.error('Failed to save state to localStorage:', e);
        }
    };

    const getCurrentState = () => {
        try {
            // Check if the stored data has expired
            const expiry = localStorage.getItem('effectStateExpiry');
            if (expiry && parseInt(expiry) < Date.now()) {
                // Expired, clear the saved state
                localStorage.removeItem('effectState');
                localStorage.removeItem('effectStateExpiry');
                return 0;
            }

            const savedState = localStorage.getItem('effectState');
            return savedState ? parseInt(savedState) : 0;
        } catch (e) {
            console.error('Failed to read state from localStorage:', e);
            return 0;
        }
    };

    // Get the button elements
    const buttons = document.querySelectorAll('.train-switch button');

    //  Update button visibility
    const updateButtonDisplay = (state) => {
        buttons.forEach((button, index) => {
            button.style.display = index === state ? 'block' : 'none';
        });
    };

    //  Initialize the page
    const currentState = getCurrentState();
    updateButtonDisplay(currentState);

    // Button click event
    buttons.forEach((button, index) => {
        button.addEventListener('click', () => {
            const newState = (index + 1) % 4; // Cycle through the states

            // Save the state to localStorage (valid for 48 hours)
            saveState(newState);

            // Update the button display
            updateButtonDisplay(newState);

            // Dispatch a custom event to notify the effect component to update
            window.dispatchEvent(new CustomEvent(EFFECT_CHANGE_EVENT, {
                detail: { state: newState }
            }));
        });
    });
</script>
